col (p=20; s=20) {
    custom_widget(id="visualize_mat"; w=0.8; bg=64,64,64; fs = 50)
    row(w=0.2; s=10) {
        rbn(id="rbn_aut") text(w=3; t="automatic"; fs=25)
        rbn(id="rbn_man") text(w=3; t="manual"; fs=25)
        rbn(id="rbn_mat") text(w=3; t="matrices"; fs=25)
        btt(id="btt_reset"; w=3; bg=100,0,0; t="RESET")
    }
}