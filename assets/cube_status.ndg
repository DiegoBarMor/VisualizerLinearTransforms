row (p=20; s=20) {
    cube_status(id="visualize_mat"; w=0.8; fs = 50)
    col(w=0.2; s=10) {
        row { rbn(id="rbn_aut") text(w=3; t="automatic"; fs=25) }
        row { rbn(id="rbn_man") text(w=3; t="keyboard"; fs=25) }
        row { rbn(id="rbn_mat") text(w=3; t="matrix"; fs=25) }
        btt(id="btt_reset"; bg=100,0,0; t="RESET")
    }
}